graph LR
    subgraph Sources["数据源 · UFS"]
        direction TB
        S3["对象存储<br/>S3 / OSS"]
        TFS["3FS<br/>高性能并行文件系统"]
        HDFS["HDFS / NFS"]
    end

    subgraph FluidLayer["Fluid 数据加速层"]
        direction TB
        DS["Dataset<br/>统一数据抽象"]
        Cache["CacheRuntime 缓存集群<br/>Curvine / Alluxio / JuiceFS<br/>分层存储 Mem / SSD"]
        PF["模型 Prefetch · DataLoad<br/>预热模型权重 / 训练数据"]
    end

    subgraph AI["AI 工作负载"]
        direction TB
        Train["训练 Job<br/>dataloader 随机读取"]
        Infer["推理服务<br/>秒级冷启动"]
    end

    KV[("分布式 KV Cache<br/>vLLM / SGLang · Mooncake<br/>Roadmap")]

    S3 --> DS
    TFS --> DS
    HDFS --> DS
    DS --> Cache
    PF ==>|预热写入| Cache
    Cache -->|高吞吐读| Train
    Cache -->|权重秒级加载| Infer
    Infer -. KV Cache 外置<br/>跨 Pod 共享 .-> KV

    classDef store fill:#F1F3F4,stroke:#5F6368,stroke-width:1px,color:#1a1a1a;
    classDef fluid fill:#E6F4EA,stroke:#34A853,stroke-width:1px,color:#1a1a1a;
    classDef pf fill:#FEF7E0,stroke:#F9AB00,stroke-width:2px,color:#1a1a1a;
    classDef ai fill:#FCE8E6,stroke:#EA4335,stroke-width:1px,color:#1a1a1a;
    classDef road fill:#F3E8FD,stroke:#A142F4,stroke-width:1px,color:#1a1a1a,stroke-dasharray:4 3;

    class S3,TFS,HDFS store;
    class DS,Cache fluid;
    class PF pf;
    class Train,Infer ai;
    class KV road;
