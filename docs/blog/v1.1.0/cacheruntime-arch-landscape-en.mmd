graph LR
    subgraph API["1 - Declarative API"]
        direction TB
        Class["CacheRuntimeClass<br/>template by provider"]
        CR["CacheRuntime<br/>instance by user"]
        DS["Dataset<br/>UFS mount"]
    end

    Ctrl["2 - CacheRuntime<br/>Controller<br/>Reconcile<br/>Spec → Pod"]

    subgraph Data["3 - Data Plane · Workloads"]
        direction TB
        Master["Master · StatefulSet<br/>metadata / Headless Svc"]
        Worker["Worker · AdvancedStatefulSet<br/>tiered store · in-place update"]
        Client["Client · DaemonSet<br/>FUSE · POSIX"]
    end

    App["Application Pod<br/>train/infer/analytics"]
    UFS[("UFS<br/>S3·OSS·HDFS·MinIO")]
    DL["DataLoad /<br/>DataProcess"]

    Class --> Ctrl
    CR --> Ctrl
    DS --> Ctrl
    Ctrl ==> Master
    Ctrl ==> Worker
    Ctrl ==> Client
    Master -. metadata .-> Worker
    App -->|POSIX I/O| Client
    Client -->|hit| Worker
    Worker -->|miss| UFS
    DL -->|warm up| Worker
    Worker -. affinity .-> App

    classDef api fill:#E8F0FE,stroke:#4285F4,stroke-width:1px,color:#1a1a1a;
    classDef ctrl fill:#FEF7E0,stroke:#F9AB00,stroke-width:2px,color:#1a1a1a;
    classDef data fill:#E6F4EA,stroke:#34A853,stroke-width:1px,color:#1a1a1a;
    classDef store fill:#F1F3F4,stroke:#5F6368,stroke-width:1px,color:#1a1a1a;
    classDef app fill:#FCE8E6,stroke:#EA4335,stroke-width:1px,color:#1a1a1a;

    class Class,CR,DS api;
    class Ctrl ctrl;
    class Master,Worker,Client data;
    class UFS store;
    class App,DL app;
